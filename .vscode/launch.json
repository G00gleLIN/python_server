{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: 调试积木解析工具",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/test.py",
            "console": "integratedTerminal",
            "justMyCode": false,
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONIOENCODING": "utf-8"
            }
        },
        {
            "name": "Python: 调试 block_parser.py",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/block_parser.py",
            "args": [
                "${workspaceFolder}/../extracted/project.json"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONIOENCODING": "utf-8"
            }
        },
        {
            "name": "Python: 启动 WebSocket 服务",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/block_server.py",
            "console": "integratedTerminal",
            "justMyCode": false,
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONIOENCODING": "utf-8"
            }
        }
    ]
}
